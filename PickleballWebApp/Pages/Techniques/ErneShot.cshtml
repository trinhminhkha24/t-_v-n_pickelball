@page
@model PickleballWebApp.Pages.Techniques.ErneShotModel
@{
    ViewData["Title"] = "Erne Shot – Cú lao ra ngoài kitchen để volley tấn công";
}

<div class="technique-hero">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb" style="background:transparent;padding:0;margin-bottom:12px;">
                <li class="breadcrumb-item"><a asp-page="/Index" style="color:rgba(255,255,255,0.7);">Trang chủ</a></li>
                <li class="breadcrumb-item" style="color:rgba(255,255,255,0.7);">Kỹ thuật</li>
                <li class="breadcrumb-item active" style="color:white;">Erne Shot</li>
            </ol>
        </nav>
        <h1>🚀 Erne Shot – Cú lao ra ngoài kitchen</h1>
        <p class="lead">Kỹ thuật nâng cao bậc nhất – bất ngờ, mạo hiểm và đẳng cấp</p>
    </div>
</div>

<div class="technique-body">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="info-card mb-4">
                    <h3><i class="fas fa-info-circle me-2"></i>Tổng quan</h3>
                    <p>Erne Shot được đặt tên theo Erne Perry – người đầu tiên phổ biến kỹ thuật này. Người chơi <strong>nhảy qua hoặc bước ra ngoài vùng Kitchen</strong> để đánh volley từ vị trí sát cạnh lưới, tạo góc tấn công cực khó trả. Đây là kỹ thuật cao cấp, đòi hỏi timing chính xác và phán đoán tốt.</p>
                    <div class="alert alert-warning mt-3" role="alert" style="border-radius:10px;">
                        <strong>⚠️ Lưu ý luật:</strong> Khi thực hiện Erne, cả hai chân phải hoàn toàn ở ngoài đường biên sân (bên ngoài cột lưới) trước khi tiếp xúc bóng. Được phép nhảy qua kitchen từ trong sân ra ngoài cột lưới.
                    </div>
                </div>

                <div class="info-card mb-4">
                    <h3><i class="fas fa-list-ol me-2"></i>Các bước thực hiện</h3>
                    <ol class="step-list">
                        <li>Nhận biết bóng đang bay về phía đường biên dọc (sideline), gần cột lưới.</li>
                        <li>Phán đoán sớm và bắt đầu di chuyển sang một bên ngay lập tức.</li>
                        <li>Bước nhanh hoặc nhảy ra ngoài đường biên dọc của sân – hoàn toàn hợp lệ theo luật.</li>
                        <li><strong>Đảm bảo cả hai chân ở ngoài sân</strong> trước khi đánh bóng – đây là điều kiện tiên quyết.</li>
                        <li>Thực hiện volley tấn công mạnh vào khoảng trống trên sân đối phương.</li>
                        <li>Nhắm chéo sân (cross-court) hoặc vào chân đối thủ.</li>
                    </ol>
                </div>

                <div class="tips-box mb-4">
                    <h3><i class="fas fa-lightbulb me-2"></i>Cách tạo cơ hội Erne</h3>
                    <ul style="padding-left:20px;color:#533f03;line-height:1.9;margin:0;">
                        <li><strong>Dink về sideline:</strong> Dink liên tục về phía đường biên để buộc đối thủ dink lại theo đường thẳng</li>
                        <li><strong>Đọc bóng sớm:</strong> Erne chỉ thực hiện được khi bạn đọc được hướng bóng từ sớm</li>
                        <li><strong>Fake Erne:</strong> Giả vờ chuẩn bị Erne để buộc đối thủ thay đổi hướng dink – sau đó dink lại bình thường</li>
                        <li><strong>Luyện với đối tác:</strong> Erne cần luyện tập nhiều với người phối hợp cố tình dink vào sideline</li>
                    </ul>
                </div>

                <div class="common-mistakes-box">
                    <h3><i class="fas fa-exclamation-triangle me-2"></i>Lỗi thường gặp</h3>
                    <ul style="margin:0;">
                        <li>Chân vẫn trong sân khi đánh → fault (vi phạm NVZ)</li>
                        <li>Di chuyển quá chậm – bỏ lỡ cơ hội hoặc đánh bóng bất tiện</li>
                        <li>Thực hiện khi bóng không đủ gần đường biên – mất cân bằng</li>
                        <li>Lạm dụng Erne quá nhiều – đối thủ học được và dink về giữa sân</li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="info-card mb-4">
                    <h3><i class="fas fa-table me-2"></i>Thông số kỹ thuật</h3>
                    <table class="spec-table">
                        <tr><td>Độ khó</td><td><span class="difficulty-badge hard">Rất khó</span></td></tr>
                        <tr><td>Phân loại</td><td>Kỹ thuật nâng cao</td></tr>
                        <tr><td>Trình độ</td><td>4.0+ DUPR</td></tr>
                        <tr><td>Yếu tố</td><td>Bất ngờ + Timing</td></tr>
                        <tr><td>Đặt tên theo</td><td>Erne Perry</td></tr>
                    </table>
                </div>
                <div class="info-card mb-4" style="background:linear-gradient(135deg,#e8f4fd,#d1ecf1);">
                    <h3 style="color:#004c6d;"><i class="fas fa-graduation-cap me-2"></i>Cần học trước</h3>
                    <p style="color:#555;font-size:0.9rem;">Nắm vững các kỹ thuật này trước khi học Erne Shot:</p>
                    <div class="d-flex flex-column gap-2 mt-2">
                        <a asp-page="/Techniques/Dink" class="btn btn-outline-primary btn-sm">🎯 Dink – Thành thạo trước</a>
                        <a asp-page="/Techniques/Volley" class="btn btn-outline-primary btn-sm">⚡ Volley – Nền tảng cần có</a>
                    </div>
                </div>
                <div class="info-card">
                    <h3><i class="fas fa-arrow-right me-2"></i>Thực hành</h3>
                    <a asp-page="/MotionCompare" class="btn btn-primary w-100"><i class="fas fa-camera me-1"></i>Phân tích động tác ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>
