@page
@model PickleballWebApp.Pages.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-logo">
            <i class="fas fa-table-tennis"></i>
            <h3>DKQ Pickleball</h3>
            <p style="color:#6c757d;font-size:0.9rem;margin-top:4px;">Đăng nhập để truy cập trang quản trị</p>
        </div>

        <form method="post">
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3" role="alert" style="font-size:0.9rem;border-radius:10px;"></div>

            <div class="mb-3">
                <label asp-for="User.Username" class="form-label">Tên đăng nhập</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#f8f9fa;border-right:none;border-radius:10px 0 0 10px;">
                        <i class="fas fa-user" style="color:#004c6d;"></i>
                    </span>
                    <input asp-for="User.Username" class="form-control" placeholder="Nhập tên đăng nhập"
                           style="border-left:none;border-radius:0 10px 10px 0;" />
                </div>
                <span asp-validation-for="User.Username" class="text-danger" style="font-size:0.85rem;"></span>
            </div>

            <div class="mb-4">
                <label asp-for="User.Password" class="form-label">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#f8f9fa;border-right:none;border-radius:10px 0 0 10px;">
                        <i class="fas fa-lock" style="color:#004c6d;"></i>
                    </span>
                    <input asp-for="User.Password" type="password" class="form-control" placeholder="Nhập mật khẩu"
                           style="border-left:none;border-radius:0 10px 10px 0;" />
                </div>
                <span asp-validation-for="User.Password" class="text-danger" style="font-size:0.85rem;"></span>
            </div>

            <button type="submit" class="btn btn-login">
                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
            </button>
        </form>

        <div class="mt-4 text-center">
            <p style="color:#6c757d;font-size:0.85rem;margin:0;">
                <i class="fas fa-info-circle me-1"></i>
                Demo: tên đăng nhập <strong>admin</strong> / mật khẩu <strong>password</strong>
            </p>
        </div>

        <hr style="margin:20px 0;">
        <div class="text-center">
            <a asp-page="/Index" style="color:#004c6d;font-size:0.9rem;text-decoration:none;">
                <i class="fas fa-arrow-left me-1"></i>Quay về trang chủ
            </a>
        </div>
    </div>
</div>
