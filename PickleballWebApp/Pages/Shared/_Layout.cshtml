<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DKQ Pickleball</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TuVanNguoiDungPickleball.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
</head>
<body>
    <header>
        <div class="top-bar">
            <div class="container">
                <div class="social-icons">
                    <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
                    <a href="#" title="TikTok"><i class="fab fa-tiktok"></i></a>
                    <a href="#" title="YouTube"><i class="fab fa-youtube"></i></a>
                    <a href="mailto:info@dkqpickleball.vn" title="Email"><i class="fas fa-envelope"></i></a>
                </div>
            </div>
        </div>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <img src="~/images/logo.png" alt="DKQ Pickleball" style="height: 44px;">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navDropdown1" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                TỔNG QUAN
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navDropdown1">
                                <li><a class="dropdown-item" asp-page="/History">
                                    <i class="fas fa-history me-2 text-muted"></i>Lịch sử Pickleball</a></li>
                                <li><a class="dropdown-item" asp-page="/Rules">
                                    <i class="fas fa-book me-2 text-muted"></i>Luật chơi</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown dropdown-hover">
                            <a class="nav-link dropdown-toggle" asp-page="/Techniques/Index" id="navDropdown2">
                                KỸ THUẬT
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navDropdown2">
                                <li><a class="dropdown-item" asp-page="/Techniques/Serve">Serve – Giao bóng</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/Return">Return – Trả giao bóng</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/Forehand">Forehand – Thuận tay</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/Backhand">Backhand – Trái tay</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/Volley">Volley – Đánh vô lê</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/Dink">Dink – Bỏ nhỏ sát lưới</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/DropShot">Drop Shot</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/Drive">Drive – Đánh mạnh</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/Lob">Lob – Lốp bóng</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/Smash">Smash / Overhead</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/BlockShot">Block Shot</a></li>
                                <li><a class="dropdown-item" asp-page="/Techniques/ErneShot">Erne Shot</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Exercises">BÀI TẬP</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navDropdown3" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                ĐÁNH GIÁ VỢT
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navDropdown3">
                                <li><a class="dropdown-item" asp-page="/PaddleBeginners">
                                    <i class="fas fa-star me-2 text-muted"></i>Vợt cho người mới</a></li>
                                <li><a class="dropdown-item" asp-page="/PaddleIntermediate">
                                    <i class="fas fa-star-half-alt me-2 text-muted"></i>Vợt trung cấp</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navDropdown4" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                ĐỊA ĐIỂM SÂN
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navDropdown4">
                                <li><a class="dropdown-item" asp-page="/CourtsHanoi">
                                    <i class="fas fa-map-marker-alt me-2 text-muted"></i>Sân ở Hà Nội</a></li>
                                <li><a class="dropdown-item" asp-page="/CourtsHCM">
                                    <i class="fas fa-map-marker-alt me-2 text-muted"></i>Sân ở TP.HCM</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navDropdown5" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                TIN TỨC
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navDropdown5">
                                <li><a class="dropdown-item" asp-page="/NewsDomestic">
                                    <i class="fas fa-flag me-2 text-muted"></i>Tin trong nước</a></li>
                                <li><a class="dropdown-item" asp-page="/NewsInternational">
                                    <i class="fas fa-globe me-2 text-muted"></i>Tin quốc tế</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/MotionCompare">
                                <i class="fas fa-camera me-1"></i>PHÂN TÍCH ĐỘNG TÁC
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @await Component.InvokeAsync("LoginStatus")
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6 footer-brand">
                    <h5><i class="fas fa-table-tennis me-2"></i>DKQ Pickleball</h5>
                    <p>Nền tảng hướng dẫn Pickleball hàng đầu Việt Nam. Học kỹ thuật, phân tích động tác, tìm sân chơi – tất cả trong một nơi.</p>
                    <div class="social-icons mt-3">
                        <a href="#" class="me-3" style="color:rgba(255,255,255,0.7);font-size:1.2rem;"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="me-3" style="color:rgba(255,255,255,0.7);font-size:1.2rem;"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="me-3" style="color:rgba(255,255,255,0.7);font-size:1.2rem;"><i class="fab fa-tiktok"></i></a>
                        <a href="#" style="color:rgba(255,255,255,0.7);font-size:1.2rem;"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-heading">Kỹ thuật</h6>
                    <ul class="footer-links">
                        <li><a asp-page="/Techniques/Serve">Giao bóng</a></li>
                        <li><a asp-page="/Techniques/Return">Trả giao bóng</a></li>
                        <li><a asp-page="/Techniques/Forehand">Forehand</a></li>
                        <li><a asp-page="/Techniques/Backhand">Backhand</a></li>
                        <li><a asp-page="/Techniques/Dink">Dink</a></li>
                        <li><a asp-page="/Techniques/Smash">Smash</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-heading">Tìm hiểu</h6>
                    <ul class="footer-links">
                        <li><a asp-page="/History">Lịch sử</a></li>
                        <li><a asp-page="/Rules">Luật chơi</a></li>
                        <li><a asp-page="/Exercises">Bài tập</a></li>
                        <li><a asp-page="/PaddleBeginners">Đánh giá vợt</a></li>
                        <li><a asp-page="/NewsDomestic">Tin trong nước</a></li>
                        <li><a asp-page="/NewsInternational">Tin quốc tế</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h6 class="footer-heading">Liên hệ</h6>
                    <ul class="footer-links">
                        <li><i class="fas fa-envelope me-2"></i>info@dkqpickleball.vn</li>
                        <li><i class="fas fa-phone me-2"></i>0123 456 789</li>
                        <li><i class="fas fa-map-marker-alt me-2"></i>Hà Nội, Việt Nam</li>
                    </ul>
                    <div class="mt-3">
                        <a asp-page="/MotionCompare" class="btn btn-sm" style="background:#f0c040;color:#003d57;font-weight:700;border-radius:8px;padding:8px 16px;">
                            <i class="fas fa-camera me-1"></i>Thử Phân Tích Động Tác
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container">
                &copy; 2026 DKQ Pickleball. Mọi quyền được bảo lưu.
                &nbsp;|&nbsp;
                <a asp-page="/Privacy">Chính sách bảo mật</a>
            </div>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
