@if (User.Identity.IsAuthenticated)
{
    <form class="d-flex align-items-center gap-2" asp-page="/Logout" method="post">
        <li class="nav-item list-unstyled">
            <a class="nav-link" asp-page="/Admin" style="color:rgba(255,255,255,0.9);">
                <i class="fas fa-user-circle me-1"></i>@User.Identity.Name
            </a>
        </li>
        <li class="nav-item list-unstyled">
            <button type="submit" class="btn btn-sm btn-outline-light">
                <i class="fas fa-sign-out-alt me-1"></i>Đăng xuất
            </button>
        </li>
    </form>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-page="/Login" style="color:rgba(255,255,255,0.9);">
            <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
        </a>
    </li>
}
