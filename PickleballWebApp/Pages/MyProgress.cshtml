@page
@model PickleballWebApp.Pages.MyProgressModel
@{
    ViewData["Title"] = "Tiến độ luyện tập";
    var totalSessions = Model.DashboardStats.TotalSessions;
    var averageAccuracy = totalSessions > 0 ? Model.DashboardStats.AverageAccuracy : 0;
    var bestAccuracy = totalSessions > 0 ? Model.DashboardStats.BestAccuracy : 0;
    var trend = Model.DashboardStats.RecentTrend;
    var trendPositive = trend > 0;
    var trendLabel = totalSessions >= 4
        ? $"{(trendPositive ? "+" : trend < 0 ? "" : "")}{Math.Abs(trend):F1}%"
        : "Chưa đủ dữ liệu";
    var lastSessionText = Model.DashboardStats.LastSessionAt.HasValue
        ? Model.DashboardStats.LastSessionAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
        : "Chưa có buổi nào";
    var nextGoal = averageAccuracy < 50 ? 50 : averageAccuracy < 65 ? 65 : averageAccuracy < 75 ? 75 : averageAccuracy < 85 ? 85 : 90;
    var goalProgress = totalSessions == 0 ? 0 : Math.Min(100, (int)Math.Round(averageAccuracy));
    var sessionsGoal = 10;
    var sessionsProgress = Math.Min(100, (int)Math.Round((double)totalSessions / sessionsGoal * 100));
    var activeRange = string.IsNullOrWhiteSpace(Model.Range) ? "30d" : Model.Range;
    var displayName = User.Identity?.IsAuthenticated == true ? (User.Identity?.Name ?? "Người dùng") : "Khách";
}

<div class="page-hero progress-hero">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb" style="background:transparent;padding:0;margin-bottom:12px;">
                <li class="breadcrumb-item"><a asp-page="/Index" style="color:rgba(255,255,255,0.7);">Trang chủ</a></li>
                <li class="breadcrumb-item active" style="color:white;">Tiến độ luyện tập</li>
            </ol>
        </nav>
        <h1><i class="fas fa-chart-line me-2"></i>Tiến độ luyện tập</h1>
        <p class="lead">Theo dõi hành trình tiến bộ của bạn, xem buổi gần nhất và biết mình đang tiến tới mốc nào tiếp theo.</p>
        <div class="progress-hero-meta">
            <span class="progress-hero-chip"><i class="fas fa-user"></i>@displayName</span>
            <span class="progress-hero-chip"><i class="fas fa-camera"></i>@totalSessions buổi đã ghi lại</span>
            <span class="progress-hero-chip"><i class="fas fa-bullseye"></i>Mục tiêu kế tiếp: @nextGoal%</span>
        </div>
    </div>
</div>

<div class="page-content">
    <div class="container">
        @if (!Model.IsAuthenticated)
        {
            <div class="info-card mb-4" style="border-top:4px solid #f0c040;">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div>
                        <h4 class="mb-2" style="color:#004c6d;font-weight:800;"><i class="fas fa-lock-open me-2"></i>Xem trang tiến độ</h4>
                        <p class="mb-0" style="color:#555;">Bạn đang xem với quyền khách. Đăng nhập để dữ liệu luyện tập, biểu đồ và lịch sử của bạn hiển thị đầy đủ.</p>
                    </div>
                    <a asp-page="/Login" class="btn btn-primary">
                        <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                    </a>
                </div>
            </div>
        }

        <div class="info-card mb-4 progress-filter-card">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h4 class="mb-1" style="color:#004c6d;font-weight:800;"><i class="fas fa-filter me-2"></i>Lọc tiến độ</h4>
                    <div style="color:#6c757d;font-size:0.9rem;">Xem nhanh theo khoảng thời gian bạn quan tâm.</div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-page="/MyProgress" asp-route-range="7d" class="btn btn-sm @(activeRange == "7d" ? "btn-primary" : "btn-outline-primary")">7 ngày</a>
                    <a asp-page="/MyProgress" asp-route-range="30d" class="btn btn-sm @(activeRange == "30d" ? "btn-primary" : "btn-outline-primary")">30 ngày</a>
                    <a asp-page="/MyProgress" asp-route-range="90d" class="btn btn-sm @(activeRange == "90d" ? "btn-primary" : "btn-outline-primary")">90 ngày</a>
                    <a asp-page="/MyProgress" asp-route-range="all" class="btn btn-sm @(activeRange == "all" ? "btn-primary" : "btn-outline-primary")">Toàn bộ</a>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-7">
                <div class="progress-summary-card h-100">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                        <div>
                            <div class="progress-kicker">Tổng quan tiến độ</div>
                            <h2 class="progress-title">Bạn đang ở mức @goalProgress% so với mục tiêu tiếp theo</h2>
                            <p class="progress-subtitle mb-0">Mỗi buổi luyện tập mới sẽ làm rõ đường tiến bộ của bạn hơn, từ độ chính xác đến độ ổn định.</p>
                        </div>
                        <div class="progress-score-badge">
                            <span>@(totalSessions > 0 ? averageAccuracy.ToString("F1") : "--")%</span>
                            <small>Độ chính xác TB</small>
                        </div>
                    </div>

                    <div class="progress-meter-label d-flex justify-content-between mb-2">
                        <span>Mục tiêu hiện tại</span>
                        <span>@nextGoal%</span>
                    </div>
                    <div class="progress progress-track mb-3" role="progressbar" aria-valuenow="@goalProgress" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar progress-bar-animated" style="width:@goalProgress%;background:linear-gradient(90deg,#004c6d,#00a8cc,#28a745);"></div>
                    </div>
                    <div class="d-flex flex-wrap gap-3 progress-summary-links">
                        <a asp-page="/MotionCompare" class="btn btn-primary">
                            <i class="fas fa-camera me-1"></i>Phân tích buổi mới
                        </a>
                        <a asp-page="/Techniques/Index" class="btn btn-outline-primary">
                            <i class="fas fa-table-tennis-paddle-ball me-1"></i>Xem kỹ thuật
                        </a>
                    </div>
                    <div style="margin-top:16px;color:#6c757d;font-size:0.85rem;">
                        Đang xem: <strong style="color:#004c6d;">@Model.RangeLabel</strong>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="progress-highlights-card h-100">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="mini-metric-card">
                                <i class="fas fa-dumbbell"></i>
                                <div class="value">@totalSessions</div>
                                <div class="label">Buổi luyện tập</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mini-metric-card success">
                                <i class="fas fa-trophy"></i>
                                <div class="value">@(totalSessions > 0 ? bestAccuracy.ToString("F1") : "--")%</div>
                                <div class="label">Điểm cao nhất</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mini-metric-card warning">
                                <i class="fas fa-bullseye"></i>
                                <div class="value">@lastSessionText</div>
                                <div class="label">Lần gần nhất</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mini-metric-card trend">
                                <i class="fas @((totalSessions >= 4 && trendPositive) ? "fa-arrow-up" : (totalSessions >= 4 && trend < 0) ? "fa-arrow-down" : "fa-minus")"></i>
                                <div class="value">@trendLabel</div>
                                <div class="label">Xu hướng gần đây</div>
                            </div>
                        </div>
                    </div>

                    <div class="progress-volume-box mt-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong style="color:#004c6d;">Mốc luyện tập @sessionsGoal buổi</strong>
                            <span style="color:#6c757d;font-size:0.85rem;">@totalSessions/@sessionsGoal buổi</span>
                        </div>
                        <div class="progress progress-track" style="height:10px;">
                            <div class="progress-bar" style="width:@sessionsProgress%;background:linear-gradient(90deg,#004c6d,#00789c,#f0c040);"></div>
                        </div>
                        <div style="display:flex;justify-content:space-between;font-size:0.78rem;color:#6c757d;margin-top:6px;">
                            <span>0</span>
                            <span>@sessionsGoal</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">

            <!-- ========== BIỂU ĐỒ ĐỘ CHÍNH XÁC ========== -->
            <div class="col-lg-8">
                <div class="info-card mb-4">
                    <h4 style="color:#004c6d;font-weight:700;margin-bottom:16px;">
                        <i class="fas fa-chart-area me-2"></i>Tiến bộ theo thời gian
                    </h4>
                    @if (Model.VisibleSessions.Count == 0)
                    {
                        <div style="text-align:center;padding:40px;color:#6c757d;">
                            <i class="fas fa-camera" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:12px;"></i>
                            Chưa có buổi luyện tập nào trong khoảng <strong>@Model.RangeLabel</strong>. Hãy thử <a asp-page="/MotionCompare">phân tích động tác</a>!
                        </div>
                    }
                    else
                    {
                        <canvas id="progress-chart" height="140" style="width:100%;"></canvas>
                        <div style="display:flex;gap:20px;margin-top:8px;font-size:0.8rem;color:#6c757d;">
                            <span><span style="display:inline-block;width:12px;height:3px;background:#004c6d;border-radius:2px;vertical-align:middle;margin-right:4px;"></span>Độ chính xác</span>
                            <span><span style="display:inline-block;width:12px;height:3px;background:rgba(40,167,69,0.5);border-radius:2px;vertical-align:middle;margin-right:4px;border-top:2px dashed #28a745;"></span>Ngưỡng tốt (75%)</span>
                        </div>
                    }
                </div>

                <div class="info-card mb-4 progress-plan-card">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                        <h4 class="mb-0" style="color:#004c6d;font-weight:700;">
                            <i class="fas fa-route me-2"></i>Lộ trình chinh phục mốc tiếp theo
                        </h4>
                        <span class="badge" style="background:#e8f4fd;color:#004c6d;font-weight:700;">Mục tiêu: @nextGoal%</span>
                    </div>
                    <div class="progress-timeline">
                        <div class="progress-timeline-item done">
                            <div class="dot"></div>
                            <div>
                                <strong>Ổn định cơ bản</strong>
                                <p>Giữ được nhịp luyện đều và có dữ liệu theo dõi.</p>
                            </div>
                        </div>
                        <div class="progress-timeline-item @(averageAccuracy >= 50 ? "done" : "")">
                            <div class="dot"></div>
                            <div>
                                <strong>Vượt 50%</strong>
                                <p>Đạt khả năng kiểm soát động tác ở mức an toàn.</p>
                            </div>
                        </div>
                        <div class="progress-timeline-item @(averageAccuracy >= 65 ? "done" : "")">
                            <div class="dot"></div>
                            <div>
                                <strong>Vượt 65%</strong>
                                <p>Bắt đầu ổn định hơn ở các pha luyện có áp lực.</p>
                            </div>
                        </div>
                        <div class="progress-timeline-item @(averageAccuracy >= 75 ? "done" : "")">
                            <div class="dot"></div>
                            <div>
                                <strong>Vượt 75%</strong>
                                <p>Mốc tốt để chuyển sang tinh chỉnh chi tiết và biến hoá kỹ thuật.</p>
                            </div>
                        </div>
                        <div class="progress-timeline-item @(averageAccuracy >= 85 ? "done" : "")">
                            <div class="dot"></div>
                            <div>
                                <strong>Vượt 85%</strong>
                                <p>Mức tiến bộ rất tốt, phù hợp để tăng độ khó bài tập.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ========== LỊCH SỬ PHIÊN LÀM VIỆC ========== -->
                <div class="info-card">
                    <h4 style="color:#004c6d;font-weight:700;margin-bottom:16px;">
                        <i class="fas fa-history me-2"></i>Lịch sử buổi luyện tập
                    </h4>
                    @if (Model.VisibleSessions.Count == 0)
                    {
                        <p style="color:#6c757d;text-align:center;padding:20px 0;">Chưa có buổi luyện tập nào được ghi lại trong khoảng thời gian này.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover" style="font-size:0.88rem;">
                                <thead>
                                    <tr style="color:#004c6d;font-weight:700;border-bottom:2px solid #004c6d;">
                                        <th>Thời gian</th>
                                        <th>Kỹ thuật</th>
                                        <th>Chế độ</th>
                                        <th class="text-center">Độ chính xác</th>
                                        <th class="text-center">Frames</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in Model.VisibleSessions)
                                    {
                                        var accColor = s.OverallAccuracy >= 75 ? "#28a745"
                                                     : s.OverallAccuracy >= 50 ? "#856404" : "#e63946";
                                        <tr>
                                            <td style="color:#6c757d;white-space:nowrap;">
                                                @s.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                            </td>
                                            <td><span class="badge" style="background:#e8f4f8;color:#004c6d;font-weight:600;">@(string.IsNullOrEmpty(s.PresetName) ? "—" : s.PresetName)</span></td>
                                            <td>
                                                @if (s.Mode == "camera")
                                                {
                                                    <span><i class="fas fa-video me-1" style="color:#004c6d;"></i>Camera</span>
                                                }
                                                else
                                                {
                                                    <span><i class="fas fa-file-video me-1" style="color:#6c757d;"></i>Video</span>
                                                }
                                            </td>
                                            <td class="text-center fw-bold" style="color:@accColor;">
                                                @s.OverallAccuracy.ToString("F1")%
                                            </td>
                                            <td class="text-center" style="color:#6c757d;">@s.NumFrames</td>
                                        </tr>
                                        @if (s.Feedback.Count > 0 || !string.IsNullOrEmpty(s.VideoUrl))
                                        {
                                            <tr style="background:#fafafa;">
                                                <td colspan="5" style="padding:6px 16px 12px;color:#555;font-size:0.82rem;">
                                                    @if (s.Feedback.Count > 0)
                                                    {
                                                        <div style="margin-bottom:@(!string.IsNullOrEmpty(s.VideoUrl) ? "8px" : "0");">
                                                            <i class="fas fa-comment-alt me-1" style="color:#004c6d;opacity:0.5;"></i>
                                                            @string.Join(" · ", s.Feedback.Take(2))
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrEmpty(s.VideoUrl))
                                                    {
                                                        <video controls width="100%" style="max-width:640px;border-radius:6px;display:block;" preload="metadata">
                                                            <source src="@s.VideoUrl" type="video/mp4" />
                                                        </video>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- ========== SIDEBAR: HOẠT ĐỘNG GẦN ĐÂY ========== -->
            <div class="col-lg-4">
                <div class="info-card mb-4">
                    <h5 style="color:#004c6d;font-weight:700;margin-bottom:14px;">
                        <i class="fas fa-map-marked-alt me-2"></i>Hoạt động gần đây
                    </h5>
                    @if (Model.RecentVisits.Count == 0)
                    {
                        <p style="color:#6c757d;font-size:0.88rem;">Chưa có hoạt động nào được ghi lại.</p>
                    }
                    else
                    {
                        <div style="max-height:360px;overflow-y:auto;">
                            @foreach (var v in Model.RecentVisits)
                            {
                                <div style="display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid #f0f0f0;">
                                    <div style="width:8px;height:8px;border-radius:50%;background:#004c6d;margin-top:5px;flex-shrink:0;"></div>
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-weight:600;color:#333;font-size:0.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                            @v.PageTitle
                                        </div>
                                        <div style="color:#6c757d;font-size:0.78rem;">
                                            @v.VisitedAt.ToLocalTime().ToString("dd/MM HH:mm")
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="info-card mb-4" style="border-top:4px solid #28a745;">
                    <h5 style="color:#004c6d;font-weight:700;margin-bottom:14px;">
                        <i class="fas fa-seedling me-2"></i>Mức độ hiện tại
                    </h5>
                    <div class="mb-2" style="font-size:0.9rem;color:#6c757d;">Dựa trên độ chính xác trung bình</div>
                    <div class="progress progress-track mb-2" style="height:10px;">
                        <div class="progress-bar" style="width:@goalProgress%;background:linear-gradient(90deg,#28a745,#f0c040,#e63946);"></div>
                    </div>
                    <div style="display:flex;justify-content:space-between;font-size:0.8rem;color:#6c757d;">
                        <span>0%</span><span>@goalProgress%</span><span>100%</span>
                    </div>
                </div>

                <!-- Phân tích kỹ thuật hay dùng nhất -->
                @{
                    var topPresets = Model.VisibleSessions
                        .Where(s => !string.IsNullOrEmpty(s.PresetName))
                        .GroupBy(s => s.PresetName)
                        .Select(g => new { Name = g.Key, Count = g.Count(), Avg = g.Average(s => s.OverallAccuracy) })
                        .OrderByDescending(x => x.Count)
                        .Take(5)
                        .ToList();
                }
                @if (topPresets.Count > 0)
                {
                    <div class="info-card mb-4">
                        <h5 style="color:#004c6d;font-weight:700;margin-bottom:14px;">
                            <i class="fas fa-star me-2"></i>Kỹ thuật luyện nhiều nhất
                        </h5>
                        @foreach (var p in topPresets)
                        {
                            var barWidth = Math.Min(100, (int)(p.Avg));
                            var barColor = p.Avg >= 75 ? "#28a745" : p.Avg >= 50 ? "#f0c040" : "#e63946";
                            <div style="margin-bottom:12px;">
                                <div style="display:flex;justify-content:space-between;margin-bottom:3px;">
                                    <span style="font-weight:600;font-size:0.85rem;color:#333;">@p.Name</span>
                                    <span style="font-size:0.8rem;color:#6c757d;">@p.Count buổi · TB @p.Avg.ToString("F0")%</span>
                                </div>
                                <div style="height:6px;background:#eee;border-radius:3px;">
                                    <div style="height:6px;width:@barWidth%;background:@barColor;border-radius:3px;transition:width 0.5s;"></div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="info-card">
                    <h5 style="color:#004c6d;font-weight:700;margin-bottom:12px;">
                        <i class="fas fa-rocket me-2"></i>Luyện tập ngay
                    </h5>
                    <a asp-page="/MotionCompare" class="btn btn-primary w-100">
                        <i class="fas fa-camera me-1"></i>Bắt đầu phân tích động tác
                    </a>
                </div>

                <div class="info-card mt-4" style="border-top:4px solid #f0c040;">
                    <h5 style="color:#004c6d;font-weight:700;margin-bottom:14px;">
                        <i class="fas fa-list-check me-2"></i>Gợi ý buổi tiếp theo
                    </h5>
                    <ul class="progress-next-steps">
                        <li>Chạy lại cùng một kỹ thuật 3 lần liên tiếp để so sánh độ ổn định.</li>
                        <li>Chọn 1 mốc cần vượt: 65%, 75% hoặc 85%.</li>
                        <li>Sau buổi luyện, mở trang tiến độ để xem đường cong thay đổi thế nào.</li>
                    </ul>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    const sessions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.VisibleSessions.Select(s => new { s.OverallAccuracy, createdAt = s.CreatedAt.ToLocalTime().ToString("dd/MM") }).ToList()
    ));

    if (!sessions || sessions.length === 0) return;

    const canvas = document.getElementById('progress-chart');
    if (!canvas) return;

    // Draw after layout is complete
    requestAnimationFrame(() => {
        const W = canvas.offsetWidth || 600;
        canvas.width = W;
        canvas.height = 140;
        const ctx = canvas.getContext('2d');
        const sorted = [...sessions].reverse(); // oldest first
        const scores = sorted.map(s => s.overallAccuracy);
        const labels = sorted.map(s => s.createdAt);
        const n = scores.length;
        const padL = 36, padR = 16, padT = 16, padB = 28;
        const W2 = W - padL - padR;
        const H2 = canvas.height - padT - padB;

        // Grid
        ctx.strokeStyle = 'rgba(0,0,0,0.06)'; ctx.lineWidth = 1;
        [0, 25, 50, 75, 100].forEach(v => {
            const y = padT + H2 - (v / 100) * H2;
            ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(padL + W2, y); ctx.stroke();
            ctx.fillStyle = '#aaa'; ctx.font = '10px sans-serif'; ctx.textAlign = 'right';
            ctx.fillText(v + '%', padL - 4, y + 3);
        });

        // 75% reference line
        const y75 = padT + H2 - 0.75 * H2;
        ctx.strokeStyle = 'rgba(40,167,69,0.4)'; ctx.lineWidth = 1;
        ctx.setLineDash([5, 5]);
        ctx.beginPath(); ctx.moveTo(padL, y75); ctx.lineTo(padL + W2, y75); ctx.stroke();
        ctx.setLineDash([]);

        // Area fill
        const step = n > 1 ? W2 / (n - 1) : 0;
        ctx.fillStyle = 'rgba(0,76,109,0.08)';
        ctx.beginPath();
        ctx.moveTo(padL, padT + H2);
        scores.forEach((s, i) => ctx.lineTo(padL + i * step, padT + H2 - (s / 100) * H2));
        ctx.lineTo(padL + (n - 1) * step, padT + H2);
        ctx.closePath(); ctx.fill();

        // Line
        ctx.strokeStyle = '#004c6d'; ctx.lineWidth = 2.5;
        ctx.beginPath();
        scores.forEach((s, i) => {
            const x = padL + i * step;
            const y = padT + H2 - (s / 100) * H2;
            i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        });
        ctx.stroke();

        // Dots + labels
        scores.forEach((s, i) => {
            const x = padL + i * step;
            const y = padT + H2 - (s / 100) * H2;
            ctx.fillStyle = s >= 75 ? '#28a745' : s >= 50 ? '#f0c040' : '#e63946';
            ctx.beginPath(); ctx.arc(x, y, 4, 0, Math.PI * 2); ctx.fill();
            // X-axis label (every ~5 points or if few)
            if (n <= 8 || i % Math.ceil(n / 8) === 0) {
                ctx.fillStyle = '#888'; ctx.font = '9px sans-serif'; ctx.textAlign = 'center';
                ctx.fillText(labels[i], x, padT + H2 + padB - 4);
            }
        });
    });
})();
</script>
}
